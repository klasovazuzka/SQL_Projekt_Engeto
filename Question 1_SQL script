--1.Rostou v průběhu let mzdy ve všech odvětvích, nebo v některých klesají?--

WITH payroll_trend AS (
    SELECT 
        cp.payroll_year AS rok,
        cpib.name AS odvetvi,
        ROUND(AVG(cp.value)) AS prumerna_mzda,
        --- Funkce LAG vrátí hodnotu mzdy z předchozího roku pro dané odvětví ---
        LAG(ROUND(AVG(cp.value))) OVER (PARTITION BY cp.industry_branch_code ORDER BY cp.payroll_year) AS mzda_predchozi_rok
    FROM czechia_payroll cp
    --- Připojíme číselník odvětví, abychom viděli jejich názvy v češtině ---
    LEFT JOIN czechia_payroll_industry_branch cpib 
        ON cp.industry_branch_code = cpib.code
    WHERE cp.value_type_code = 5958     -- Průměrná mzda --
      AND cp.calculation_code = 200     -- Přepočtený počet zaměstnanců --
      AND cp.industry_branch_code IS NOT NULL  -- Pouze konkrétní odvětví (vynecháme celkový průměr ČR)
    GROUP BY cp.payroll_year, cpib.name, cp.industry_branch_code
)
SELECT 
    rok,
    odvetvi,
    prumerna_mzda,
    mzda_predchozi_rok,
    --- Spočítáme rozdíl mezi aktuálním a předchozím rokem ---
    prumerna_mzda - mzda_predchozi_rok AS rozdil_v_kc,
    --- Označíme, zda mzda klesla nebo stoupla ---
    CASE 
        WHEN mzda_predchozi_rok IS NULL THEN 'První rok v datech'
        WHEN prumerna_mzda > mzda_predchozi_rok THEN 'Růst'
        WHEN prumerna_mzda < mzda_predchozi_rok THEN 'Pokles'
        ELSE 'Beze změny'
    END AS trend
FROM payroll_trend
ORDER BY odvetvi, rok;
